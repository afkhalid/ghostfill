{
  "name": "@afkhalid/ghostfill",
  "version": "0.2.1",
  "description": "Stop demoing with test123. Realistic, domain-aware form data in one click.",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./server": {
      "types": "./dist/server.d.ts",
      "import": "./dist/server.mjs",
      "require": "./dist/server.js"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "demo": "npx serve demo"
  },
  "keywords": [
    "form-filler",
    "ai",
    "openai",
    "fake-data",
    "testing",
    "developer-tool"
  ],
  "author": "afkhalid",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/AhmedFathyDev/ghostfill.git"
  },
  "homepage": "https://github.com/AhmedFathyDev/ghostfill#readme",
  "bugs": {
    "url": "https://github.com/AhmedFathyDev/ghostfill/issues"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.4.0"
  }
}
