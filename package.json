{
  "name": "ghostfill",
  "version": "0.1.2",
  "description": "Dev tool that fills form fields with relevant sample data — select a block, click fill, done",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "demo": "npx serve demo"
  },
  "keywords": [
    "form-filler",
    "ai",
    "openai",
    "fake-data",
    "testing",
    "developer-tool"
  ],
  "author": "afkhalid",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/afkhalid/ghostfill.git"
  },
  "homepage": "https://github.com/afkhalid/ghostfill#readme",
  "bugs": {
    "url": "https://github.com/afkhalid/ghostfill/issues"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.4.0"
  }
}
